# Web application environment (Next.js API routes).
# Copy to web/.env.local for local development.
# Set the same keys in Amplify Hosting environment variables for production.

AWS_REGION=us-east-1

# From `cdk deploy` outputs (TableName, QueueUrl).
# Leave SQS_QUEUE_URL empty for local dev — jobs stay in DynamoDB for the dev runner.
DYNAMODB_TABLE_NAME=llms-txt-generator
SQS_QUEUE_URL=

# Local development: point at DynamoDB Local
DYNAMODB_ENDPOINT=http://localhost:8000
